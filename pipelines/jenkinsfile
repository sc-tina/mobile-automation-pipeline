pipeline {
    agent any
    tools { jdk 'JDK17'; gradle '8.5' }
    stages {
        stage('Checkout') { steps { checkout scm } }
        stage('Lint') { steps { sh 'if [ -f gradlew ]; then ./gradlew lint; fi' } }
        stage('Unit Test') { steps { sh 'if [ -f gradlew ]; then ./gradlew testDebugUnitTest; fi' } }
        stage('Build APK') { steps { sh 'if [ -f gradlew ]; then ./gradlew assembleDebug; fi' } }
        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'app/build/outputs/apk/debug/*.apk'
                junit 'app/build/reports/tests/**/*.xml'
            }
        }
    }
    post {
        failure { emailext(subject: "Build failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}", to: 'team@example.com') }
        success { slackSend(channel: '#mobile-builds', message: "Build succeeded: ${env.JOB_NAME} #${env.BUILD_NUMBER}") }
    }
}
